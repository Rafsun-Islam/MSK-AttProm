ok=True)\n\nFILES = {\n    \"nonPromoter\": \"nonPromoter.fasta\",\n    \"sigma24\": \"sigma24.fasta\",\n    \"sigma28\": \"sigma28.fasta\",\n    \"sigma32\": \"sigma32.fasta\",\n    \"sigma38\": \"sigma38.fasta\",\n    \"sigma54\": \"sigma54.fasta\",\n    \"sigma70\": \"sigma70.fasta\",\n}\n\nRAW_BASE_URL = \"https://raw.githubusercontent.com/BioinformaticsLabAtMUN/Promotech/master/datasets/benchmark/iPromoter-2L\"\n\nSIGMA_TO_ID = {\n    \"sigma24\": 0,\n    \"sigma28\": 1,\n    \"sigma32\": 2,\n    \"sigma38\": 3,\n    \"sigma54\": 4,\n    \"sigma70\": 5,\n}\n\nSIGMA_NAMES = [\"sigma24\", \"sigma28\", \"sigma32\", \"sigma38\", \"sigma54\", \"sigma70\"]\n\n\ndef download_dataset(data_dir=DATA_DIR):\n    for class_name, filename in FILES.items():\n        url = f\"{RAW_BASE_URL}/{filename}\"\n        out_path = data_dir / filename\n\n        if out_path.exists() and out_path.stat().st_size > 0:\n            print(f\"[SKIP] {filename}\")\n            continue\n\n        print(f\"[DOWNLOADING] {filename}\")\n        urllib.request.urlretrieve(url, out_path)\n\n    print(\"Dataset download complete.\")\n\n\ndef parse_fasta(filepath):\n    records = []\n    seq_id = None\n    seq_chunks = []\n\n    with open(filepath, \"r\") as f:\n        for line in f:\n            line = line.strip()\n\n            if not line:\n                continue\n\n            if line.startswith(\">\"):\n                if seq_id is not None:\n                    records.append({\n                        \"id\": seq_id,\n                        \"sequence\": \"\".join(seq_chunks).upper()\n                    })\n\n                seq_id = line[1:].strip()\n                seq_chunks = []\n\n            else:\n                seq_chunks.append(line.upper())\n\n        if seq_id is not None:\n            records.append({\n                \"id\": seq_id,\n                \"sequence\": \"\".join(seq_chunks).upper()\n            })\n\n    return records\n\n\ndef is_valid_dna(seq):\n    return bool(re.fullmatch(r\"[ACGT]+\", seq))\n\n\ndef load_ipromoter2l(data_dir=DATA_DIR):\n    rows = []\n\n    for class_name, filename in FILES.items():\n        filepath = data_dir / filename\n\n        if not filepath.exists():\n            raise FileNotFoundError(f\"Missing file: {filepath}\")\n\n        records = parse_fasta(filepath)\n\n        for rec in records:\n            seq = rec[\"sequence\"]\n\n            if class_name == \"nonPromoter\":\n                binary_label = 0\n                sigma_label = None\n                sigma_id = -1\n            else:\n                binary_label = 1\n                sigma_label = class_name\n                sigma_id = SIGMA_TO_ID[class_name]\n\n            rows.append({\n                \"seq_id\": rec[\"id\"],\n                \"sequence\": seq,\n                \"class_name\": class_name,\n                \"binary_label\": binary_label,\n                \"sigma_label\": sigma_label,\n                \"sigma_id\": sigma_id,\n                \"length\": len(seq),\n                \"valid_dna\": is_valid_dna(seq),\n                \"gc_content\": (seq.count(\"G\") + seq.count(\"C\")) / len(seq)\n            })\n\n    return pd.DataFrame(rows)\n\n\ndownload_dataset()\ndf = load_ipromoter2l()\n\nprint(\"Dataset shape:\", df.shape)\ndisplay(df.head())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-03T15:42:21.281814Z","iopub.execute_input":"2026-05-03T15:42:21.282329Z","iopub.status.idle":"2026-05-03T15:42:22.345847Z","shell.execute_reply.started":"2026-05-03T15:42:21.282301Z","shell.execute_reply":"2026-05-03T15:42:22.345199Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# Section 3: Dataset Sanity Check and GC-content Analysis\n# ============================================================\n\nprint(\"Class distribution:\")\ndisplay(df[\"class_name\"].value_counts().sort_index())\n\nprint(\"\\nBinary label distr