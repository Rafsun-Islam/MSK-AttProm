c\", \"roc_auc\"]\n    mean_df = fold_df.groupby(\"model\")[metric_cols].mean()\n    std_df = fold_df.groupby(\"model\")[metric_cols].std()\n\n    summary_df = mean_df.copy()\n    for col in metric_cols:\n        summary_df[col + \"_std\"] = std_df[col]\n\n    return fold_df, summary_df.reset_index().sort_values(by=\"f1\", ascending=False)\n\n\ndef cross_validate_sigma_models(models, X, y, n_splits=5):\n    skf = StratifiedKFold(\n        n_splits=n_splits,\n        shuffle=True,\n        random_state=RANDOM_STATE\n    )\n\n    fold_results = []\n\n    for model_name, model in models.items():\n        print(f\"\\nSigma CV: {model_name}\")\n\n        for fold, (train_idx, val_idx) in enumerate(skf.split(X, y), start=1):\n            X_tr, X_val = X[train_idx], X[val_idx]\n            y_tr, y_val = y[train_idx], y[val_idx]\n\n            clf = clone(model)\n            clf.fit(X_tr, y_tr)\n\n            y_pred = clf.predict(X_val)\n\n            roc_auc = np.nan\n            if hasattr(clf, \"predict_proba\"):\n                try:\n                    y_prob = clf.predict_proba(X_val)\n                    y_val_bin = label_binarize(y_val, classes=np.unique(y))\n\n                    roc_auc = roc_auc_score(\n                        y_val_bin,\n                        y_prob,\n                        average=\"macro\",\n                        multi_class=\"ovr\"\n                    )\n                except Exception:\n                    roc_auc = np.nan\n\n            fold_results.append({\n                \"model\": model_name,\n                \"fold\": fold,\n                \"accuracy\": accuracy_score(y_val, y_pred),\n                \"precision_macro\": precision_score(y_val, y_pred, average=\"macro\", zero_division=0),\n                \"recall_macro\": recall_score(y_val, y_pred, average=\"macro\", zero_division=0),\n                \"f1_macro\": f1_score(y_val, y_pred, average=\"macro\", zero_division=0),\n                \"precision_weighted\": precision_score(y_val, y_pred, average=\"weighted\", zero_division=0),\n                \"recall_weighted\": recall_score(y_val, y_pred, average=\"weighted\", zero_division=0),\n                \"f1_weighted\": f1_score(y_val, y_pred, average=\"weighted\", zero_division=0),\n                \"mcc\": matthews_corrcoef(y_val, y_pred),\n                \"roc_auc_macro\": roc_auc\n            })\n\n    fold_df = pd.DataFrame(fold_results)\n\n    metric_cols = [\n        \"accuracy\",\n        \"precision_macro\",\n        \"recall_macro\",\n        \"f1_macro\",\n        \"precision_weighted\",\n        \"recall_weighted\",\n        \"f1_weighted\",\n        \"mcc\",\n        \"roc_auc_macro\"\n    ]\n\n    mean_df = fold_df.groupby(\"model\")[metric_cols].mean()\n    std_df = fold_df.groupby(\"model\")[metric_cols].std()\n\n    summary_df = mean_df.copy()\n    for col in metric_cols:\n        summary_df[col + \"_std\"] = std_df[col]\n\n    return fold_df, summary_df.reset_index().sort_values(by=\"f1_macro\", ascending=False)\n\n\ndef format_mean_std_table(summary_df, metrics, decimals=4):\n    rows = []\n\n    for _, row in summary_df.iterrows():\n        formatted = {\"model\": row[\"model\"]}\n\n        for metric in metrics:\n            formatted[metric] = f\"{row[metric]:.{decimals}f} ± {row[metric + '_std']:.{decimals}f}\"\n\n        rows.append(formatted)\n\n    return pd.DataFrame(rows)\n\n\nbinary_cv_folds_df, binary_cv_summary_df = cross_validate_binary_models(\n    binary_models,\n    X_all,\n    y_binary,\n    n_splits=N_SPLITS\n)\n\nsigma_cv_folds_df, sigma_cv_summary_df = cross_validate_sigma_models(\n    sigma_models,\n    X_sigma_all,\n    y_sigma_clean,\n    n_splits=N_SPLITS\n)\n\nbinary_cv_paper_table = format_mean_std_table(\n    binary_cv_summary_df,\n    metrics=[\"accuracy\", \"precision\", \"recall\", \"f1\", \"mcc\", \"roc_auc\"]\n)\n\nsigma_cv_paper_table = format_mean_std_table(\n    sigma_cv_summary_df,\n    metrics=[\n        \"accuracy\",\n        