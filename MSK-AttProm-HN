ix(sequences, k, kmer_vocab):\n    features = [kmer_frequency(seq, k, kmer_vocab) for seq in sequences]\n    return np.vstack(features)\n\n\nkmers_3 = generate_all_kmers(3)\nkmers_4 = generate_all_kmers(4)\nkmers_5 = generate_all_kmers(5)\n\nprint(\"Number of 3-mers:\", len(kmers_3))\nprint(\"Number of 4-mers:\", len(kmers_4))\nprint(\"Number of 5-mers:\", len(kmers_5))\n\nsequences = df[\"sequence\"].values\n\nX3 = build_kmer_matrix(sequences, 3, kmers_3)\nX4 = build_kmer_matrix(sequences, 4, kmers_4)\nX5 = build_kmer_matrix(sequences, 5, kmers_5)\n\nX_all = np.concatenate([X3, X4, X5], axis=1)\n\ny_binary = df[\"binary_label\"].values\ny_sigma = df[\"sigma_id\"].values\n\nprint(\"X3 shape:\", X3.shape)\nprint(\"X4 shape:\", X4.shape)\nprint(\"X5 shape:\", X5.shape)\nprint(\"X_all shape:\", X_all.shape)\nprint(\"y_binary shape:\", y_binary.shape)\nprint(\"y_sigma shape:\", y_sigma.shape)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-03T15:42:22.736019Z","iopub.execute_input":"2026-05-03T15:42:22.736348Z","iopub.status.idle":"2026-05-03T15:42:24.148507Z","shell.execute_reply.started":"2026-05-03T15:42:22.736321Z","shell.execute_reply":"2026-05-03T15:42:24.147682Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# Section 5: Train / Validation / Test Splits\n# ============================================================\n\ndef make_train_val_test_indices(y, test_size=0.2, val_size=0.1, seed=42):\n    indices = np.arange(len(y))\n\n    train_val_idx, test_idx = train_test_split(\n        indices,\n        test_size=test_size,\n        random_state=seed,\n        stratify=y\n    )\n\n    y_train_val = y[train_val_idx]\n    relative_val_size = val_size / (1.0 - test_size)\n\n    train_idx, val_idx = train_test_split(\n        train_val_idx,\n        test_size=relative_val_size,\n        random_state=seed,\n        stratify=y_train_val\n    )\n\n    return train_idx, val_idx, test_idx\n\n\n# Binary split\ntrain_idx_bin, val_idx_bin, test_idx_bin = make_train_val_test_indices(\n    y_binary,\n    test_size=0.2,\n    val_size=0.1,\n    seed=SEED\n)\n\nprint(\"Binary split sizes:\")\nprint(\"Train:\", len(train_idx_bin))\nprint(\"Val:\", len(val_idx_bin))\nprint(\"Test:\", len(test_idx_bin))\n\n\n# Sigma promoter-only split\npromoter_indices = np.where(y_binary == 1)[0]\n\nX3_sigma_all = X3[promoter_indices]\nX4_sigma_all = X4[promoter_indices]\nX5_sigma_all = X5[promoter_indices]\nX_sigma_all = X_all[promoter_indices]\ny_sigma_clean = y_sigma[promoter_indices]\n\ntrain_idx_sigma, val_idx_sigma, test_idx_sigma = make_train_val_test_indices(\n    y_sigma_clean,\n    test_size=0.2,\n    val_size=0.1,\n    seed=SEED\n)\n\nprint(\"\\nSigma split sizes:\")\nprint(\"Train:\", len(train_idx_sigma))\nprint(\"Val:\", len(val_idx_sigma))\nprint(\"Test:\", len(test_idx_sigma))\n\nprint(\"\\nBinary train distribution:\")\ndisplay(pd.Series(y_binary[train_idx_bin]).value_counts())\n\nprint(\"\\nSigma train distribution:\")\ndisplay(pd.Series(y_sigma_clean[train_idx_sigma]).value_counts().sort_index())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-03T15:42:24.149584Z","iopub.execute_input":"2026-05-03T15:42:24.149936Z","iopub.status.idle":"2026-05-03T15:42:24.186473Z","shell.execute_reply.started":"2026-05-03T15:42:24.149906Z","shell.execute_reply":"2026-05-03T15:42:24.185906Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# Section 6: Evaluation Utilities\n# ============================================================\n\ndef evaluate_binary_model(model, X_test, y_test, model_name=\"Model\"):\n    y_pred = model.predict(X_test)\n\n    if hasattr(model, \"predict_proba\"):\n        y_score = model.predict_proba(X_test)[:, 1]\n    elif hasattr(model, \"decision_function\"):\n        y_score = model.decision_function(X_test)\n    else: