 __len__(self):\n        return len(self.y)\n\n    def __getitem__(self, idx):\n        return {\n            \"x\": self.X[idx],\n            \"y\": self.y[idx]\n        }\n\n\ndef make_multiscale_loader(X3_data, X4_data, X5_data, y, batch_size=128, shuffle=False):\n    dataset = MultiScaleKmerDataset(X3_data, X4_data, X5_data, y)\n    return DataLoader(\n        dataset,\n        batch_size=batch_size,\n        shuffle=shuffle,\n        num_workers=2,\n        pin_memory=True\n    )\n\n\ndef make_single_loader(X, y, batch_size=128, shuffle=False):\n    dataset = SingleScaleKmerDataset(X, y)\n    return DataLoader(\n        dataset,\n        batch_size=batch_size,\n        shuffle=shuffle,\n        num_workers=2,\n        pin_memory=True\n    )\n\n\ndef make_concat_loader(X3_data, X4_data, X5_data, y, batch_size=128, shuffle=False):\n    dataset = ConcatKmerDataset(X3_data, X4_data, X5_data, y)\n    return DataLoader(\n        dataset,\n        batch_size=batch_size,\n        shuffle=shuffle,\n        num_workers=2,\n        pin_memory=True\n    )","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-03T15:54:35.422159Z","iopub.execute_input":"2026-05-03T15:54:35.422372Z","iopub.status.idle":"2026-05-03T15:54:35.554415Z","shell.execute_reply.started":"2026-05-03T15:54:35.422352Z","shell.execute_reply":"2026-05-03T15:54:35.553829Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ============================================================\n# Section 11: MSK-AttProm Model Classes\n# ============================================================\n\nclass MSKAttProm(nn.Module):\n    \"\"\"\n    Initial MSK-AttProm model.\n    Used as the final sigma-type model because it achieved stronger macro-F1.\n    \"\"\"\n\n    def __init__(\n        self,\n        dim3=64,\n        dim4=256,\n        dim5=1024,\n        hidden_dim=128,\n        fusion_dim=128,\n        num_classes=2,\n        dropout=0.30\n    ):\n        super().__init__()\n\n        self.branch3 = nn.Sequential(\n            nn.Linear(dim3, hidden_dim),\n            nn.BatchNorm1d(hidden_dim),\n            nn.ReLU(),\n            nn.Dropout(dropout),\n            nn.Linear(hidden_dim, fusion_dim),\n            nn.BatchNorm1d(fusion_dim),\n            nn.ReLU()\n        )\n\n        self.branch4 = nn.Sequential(\n            nn.Linear(dim4, hidden_dim),\n            nn.BatchNorm1d(hidden_dim),\n            nn.ReLU(),\n            nn.Dropout(dropout),\n            nn.Linear(hidden_dim, fusion_dim),\n            nn.BatchNorm1d(fusion_dim),\n            nn.ReLU()\n        )\n\n        self.branch5 = nn.Sequential(\n            nn.Linear(dim5, hidden_dim),\n            nn.BatchNorm1d(hidden_dim),\n            nn.ReLU(),\n            nn.Dropout(dropout),\n            nn.Linear(hidden_dim, fusion_dim),\n            nn.BatchNorm1d(fusion_dim),\n            nn.ReLU()\n        )\n\n        self.attention_layer = nn.Sequential(\n            nn.Linear(fusion_dim, fusion_dim // 2),\n            nn.Tanh(),\n            nn.Linear(fusion_dim // 2, 1)\n        )\n\n        self.classifier = nn.Sequential(\n            nn.Linear(fusion_dim, fusion_dim),\n            nn.ReLU(),\n            nn.Dropout(dropout),\n            nn.Linear(fusion_dim, num_classes)\n        )\n\n    def forward(self, x3, x4, x5, return_attention=False):\n        h3 = self.branch3(x3)\n        h4 = self.branch4(x4)\n        h5 = self.branch5(x5)\n\n        branches = torch.stack([h3, h4, h5], dim=1)\n        scores = self.attention_layer(branches).squeeze(-1)\n        attn_weights = F.softmax(scores, dim=1)\n\n        fused = torch.sum(branches * attn_weights.unsqueeze(-1), dim=1)\n        logits = self.classifier(fused)\n\n        if return_attention:\n            return logits, attn_weights\n\n        return logits\n\n\nclass MSKAttPromSmall(nn.Module):\n    \"\"\"\n    Regularized MSK-AttProm model.\n    Used as the final binary promoter prediction model.\n    \"\"\"\n\n    def __init__(\n        self,\n        dim3=64,\n        dim4=256,\n        dim5=1024,\n        hidden_dim=64,\n        fusion_dim=64,\n        num_classes=2,\n        dropout=0.45\n    ):\n        super().__init__()\n\n        self.branch3 = nn.Sequential(\n            nn.Linear(dim3, hidden_dim),\n            nn.ReLU(),\n            nn.Dropout(dropout),\n            nn.Linear(hidden_dim, fusion_dim),\n            nn.ReLU()\n        )\n\n        self.branch4 = nn.Sequential(\n            nn.Linear(dim4, hidden_dim),\n            nn.ReLU(),\n            nn.Dropout(dropout),\n            nn.Linear(hidden_dim, fusion_dim),\n            nn.ReLU()\n        )\n\n        self.branch5 = nn.Sequential(\n            nn.Linear(dim5, hidden_dim),\n            nn.ReLU(),\n            nn.Dropout(dropout),\n            nn.Linear(hidden_dim, fusion_dim),\n            nn.ReLU()\n        )\n\n        self.attention_layer = nn.Sequential(\n            nn.Linear(fusion_dim, 32),\n            nn.Tanh(),\n            nn.Linear(32, 1)\n        )\n\n        self.classifier = nn.Sequential(\n            nn.Linear(fusion_dim, 64),\n            nn.ReLU(),\n            nn.Dropout(dropout),\n            nn.Linear(64, num_classes)\n        )\n\n    def forward(self, x3, x4, x5, return_attention=False):\n        h3 = self.branch3(x3)\n        h4 = self.branch4(x4)\n        h5 = self.branch5(x5)\n\n        branches = torch.stack([h3, h4, h5], dim=1)\n        scores = self.attention_layer(branches).squeeze(-1)\n        attn_weights = F.softmax(scores, dim=1)\n\n        fused = torch.sum(branches * attn_weights.unsqueeze(-1), dim=1)\n        logits = self.classifier(fused)\n\n        if return_attention:\n            return logits, attn_weights\n\n        return logits\n\n\nclass SingleScaleMLP(nn.Module):\n    def __init__(self, input_dim, hidden_dim=64, num_classes=2, dropout=0.45):\n        super().__init__()\n\n        self.net = nn.Sequential(\n            nn.Linear(input_dim, hidden_dim),\n   